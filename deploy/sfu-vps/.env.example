# the reference VPS profile keeps these secrets in env for simple bootstrap
# production operators should prefer file backed secrets or their secret manager
GRAFANA_IMAGE=ghcr.io/thanhdodeurodoo/o-sfu-telemetry-grafana:master
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-password
GRAFANA_ROOT_URL=https://<SFU_URL_DOMAIN>/grafana/
DIAGNOSTICS_AUTH_TOKEN=change-this-diagnostics-token
ALERTMANAGER_WEBHOOK_URL_FILE=../../alertmanager/webhook-url.example
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=2GB
