{
  "annotations": {
    "list": []
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "The number of users with a stable, active media connection. This is the primary metric for 'who is actually in the call'.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(osfu_transport_health_users{state=\"connected\"})",
          "refId": "A"
        }
      ],
      "title": "Connected Transports",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The number of users whose media connection has failed or closed. A high number here relative to 'Connected' indicates network trouble.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(osfu_transport_health_users{state=\"disconnected\"})",
          "refId": "A"
        }
      ],
      "title": "Disconnected Transports",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The rate at which active connections are failing. Frequent transitions indicate a 'jittery' network or server-side instability.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(osfu_transport_health_transitions_total{from=\"connected\",to=\"disconnected\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "Disconnect Transitions/s",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Tracks the technical progress of establishing a connection (e.g., 'Checking', 'Completed', 'Failed'). Use this to debug why users are getting stuck during the join process.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (state) (rate(osfu_transport_ice_state_changes_total[5m]))",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "title": "ICE State Changes",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "A detailed look at how connection health moves between states like 'Stable', 'Weak', and 'Disconnected'. Helps identify subtle network degradation.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (from, to) (rate(osfu_transport_health_transitions_total[5m]))",
          "legendFormat": "{{from}} -> {{to}}",
          "refId": "A"
        }
      ],
      "title": "Transport Health Transitions",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows how long 95% of users stay in a call. Unexpectedly short lifetimes can indicate that users are being kicked out or experiencing crashes.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(osfu_transport_user_lifetime_seconds_bucket[30m])))",
          "legendFormat": "user lifetime p95",
          "refId": "A"
        }
      ],
      "title": "User Lifetime p95",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Compares the rate of successful secure connections (DTLS) against the rate of disconnections. This highlights if security handshakes are a bottleneck.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(osfu_transport_dtls_connected_total[5m]))",
          "legendFormat": "dtls connected/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(osfu_ws_user_loop_exits_total{reason=\"transport_disconnected\"}[5m]))",
          "legendFormat": "ws transport exits/s",
          "refId": "B"
        }
      ],
      "title": "DTLS and Transport Disconnects",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows the server's attempts to 'clean up' abandoned resources after a disconnection. A high success rate here means the server is effectively preventing memory leaks.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "id": 8,
      "targets": [
        {
          "expr": "osfu:transport_cleanup_retry_rate_5m",
          "legendFormat": "retry attempts/s",
          "refId": "A"
        },
        {
          "expr": "osfu:transport_cleanup_retry_success_rate_5m",
          "legendFormat": "retry successes/s",
          "refId": "B"
        }
      ],
      "title": "Cleanup Retry Recovery",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Identifies specific types of errors that occurred while trying to close old connections. This helps developers find bugs in the session shutdown logic.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum by (kind) (rate(osfu_transport_cleanup_failures_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "title": "Cleanup Failures by Kind",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "o-sfu",
    "phase-2"
  ],
