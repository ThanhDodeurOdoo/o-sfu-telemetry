{
  "title": "o-sfu Channel Graph",
  "uid": "channel-graph",
  "schemaVersion": 39,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "channel_uuid",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "query": "",
        "label": "Selected Channel UUID"
      },
      {
        "name": "user_id",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "query": "",
        "label": "Diagnostics User ID"
      }
    ]
  },
  "panels": [
    {
      "type": "table",
      "title": "Active Rooms (Select a room to view topology)",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:8070/internal/diagnostics/rooms",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "",
          "columns": [
            { "selector": "uuid", "text": "UUID", "type": "string" },
            { "selector": "userCount", "text": "Users", "type": "number" },
            { "selector": "createDate", "text": "Created", "type": "string" }
          ],
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "links": [
              {
                "title": "View Topology",
                "url": "/d/channel-graph/o-sfu-channel-graph?var-channel_uuid=${__data.fields.UUID}"
              }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "table",
      "title": "User Lookup: ${user_id}",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:8070/internal/diagnostics/users/${user_id}",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "",
          "columns": [
            { "selector": "roomId", "text": "Room", "type": "string" },
            { "selector": "user.userId", "text": "User", "type": "string" },
            { "selector": "user.transport.connectionId", "text": "Connection", "type": "number" },
            { "selector": "recordingState.recording", "text": "Recording", "type": "string" }
          ],
          "refId": "A"
        }
      ],
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 }
    },
    {
      "type": "nodeGraph",
      "title": "Room Topology: ${channel_uuid}",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "targets": [
        {
          "type": "json",
          "source": "url",
          "format": "node-graph-nodes",
          "url": "http://host.docker.internal:8070/internal/diagnostics/node-graph/channels/${channel_uuid}",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "nodes",
          "refId": "A"
        },
        {
          "type": "json",
          "source": "url",
          "format": "node-graph-edges",
          "url": "http://host.docker.internal:8070/internal/diagnostics/node-graph/channels/${channel_uuid}",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "edges",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 14, "w": 18, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "Source Selection Updates",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (selector) (rate(osfu_source_selection_updates_total[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 14, "w": 6, "x": 18, "y": 14 }
    }
  ]
}
