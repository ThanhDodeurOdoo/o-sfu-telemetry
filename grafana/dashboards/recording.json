  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "The total number of rooms currently being recorded. Use this to monitor the load on the recording service.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(osfu_recording_rooms_active)",
          "refId": "A"
        }
      ],
      "title": "Active Recording Rooms",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The rate at which new recording requests are being successfully started. A value of zero means no new recordings have started recently.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(osfu_recording_actions_total{action=\"start\",outcome=\"accepted\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "Accepted Starts/s",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The rate at which recording requests (start, stop, etc.) are being denied by the server. Rising values usually indicate permission issues or server resource limits.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(osfu_recording_actions_total{outcome=\"rejected\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "Rejected Actions/s",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "A timeline of all recording-related events. It shows the balance between 'start' and 'stop' requests and whether they were successful or failed.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (action, outcome) (rate(osfu_recording_actions_total[5m]))",
          "legendFormat": "{{action}} {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Recording Actions",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Measures the raw amount of media data being sent to the recording engine. High values indicate the recording service is processing a lot of video/audio data.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(osfu_recording_captured_packets_total[1m]))",
          "legendFormat": "captured packets/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(osfu_recording_captured_streams_total[5m]))",
          "legendFormat": "captured streams/s",
          "refId": "B"
        }
      ],
      "title": "Capture Throughput",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows the number of media packets being copied specifically for recording purposes. This represents the 'extra work' the server does to support recording.",
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(osfu_rtp_forwarded_packets_total{destination=\"recording\"}[1m]))",
          "legendFormat": "forwarded to recording/s",
          "refId": "A"
        }
      ],
      "title": "Recording Fan-out",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
