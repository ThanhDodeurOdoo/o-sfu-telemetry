  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "The volume of actual audio/video data entering (ingress) and leaving (egress) the server. Egress is usually much higher as one person broadcasting is sent to many viewers.",
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(osfu_rtp_payload_bytes_total{direction=\"ingress\"}[1m])) * 8",
          "legendFormat": "ingress",
          "refId": "A"
        },
        {
          "expr": "sum(rate(osfu_rtp_payload_bytes_total{direction=\"egress\"}[1m])) * 8",
          "legendFormat": "egress",
          "refId": "B"
        }
      ],
      "title": "RTP Payload Bitrate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Tracks where packets are being sent after they reach the SFU. 'local_rtc' represents internal processing, while other labels represent physical network interfaces.",
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (destination) (rate(osfu_rtp_forwarded_packets_total[1m]))",
          "legendFormat": "{{destination}}",
          "refId": "A"
        }
      ],
      "title": "Forwarded Packets by Destination",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows which internal logic paths are being used to move data. This helps developers verify that the 'fast path' is being used for media instead of slower 'fallback' paths.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (path) (rate(osfu_rtc_datagram_routes_total[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "RTC Datagram Routing Paths",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "A critical graph showing exactly why media data is being lost. 'No user' means the recipient left, 'Congestion' means the network is full, and 'Rate Limit' means the server is protecting itself.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (reason) (rate(osfu_rtc_datagram_drops_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "RTC Datagram Drops",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Measures how hard the server is working to find valid recipients for incoming media. Sudden spikes here can indicate high CPU usage and potential lag.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
