      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(osfu_rtc_datagram_fallback_scans_total[5m]))",
          "legendFormat": "fallback scans/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(osfu_rtc_datagram_scan_users_total[5m]))",
          "legendFormat": "scanned users/s",
          "refId": "B"
        }
      ],
      "title": "Routing Pressure",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows the result of internal routing decisions (e.g., 'Success', 'Skipped', or 'Error'). Use this to verify that media is being routed correctly to every subscriber.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
