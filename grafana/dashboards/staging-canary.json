  "panels": [
    {
      "datasource": "Prometheus",
      "description": "A basic heartbeat check. 1 means the canary server is responding to API requests, 0 means it is down or frozen.",
      "fieldConfig": {
        "defaults": {
          "unit": "bool"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "max(probe_success{job=\"o-sfu-noop\"})",
          "refId": "A"
        }
      ],
      "title": "Noop Probe",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The percentage of users who successfully joined a room on the canary server. This should stay close to 100% if the new code is working correctly.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "match": "null",
                "result": {
                  "text": "No recent joins"
                }
              },
              "type": "special"
            }
          ],
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "osfu:ws_join_success_ratio_active_5m",
          "refId": "A"
        }
      ],
      "title": "Join Success Ratio",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The number of users currently in a call on this canary server. Use this to gauge how much traffic the test version is handling.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(osfu_transport_health_users{state=\"connected\"})",
          "refId": "A"
        }
      ],
      "title": "Connected Transports",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Measures if media is being correctly forwarded inside the canary server. A drop below 100% means the new code might be dropping packets improperly.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "match": "null",
                "result": {
                  "text": "No recent ingress"
                }
              },
              "type": "special"
            }
          ],
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "osfu:local_forwarding_efficiency_active_5m",
          "refId": "A"
        }
      ],
      "title": "Local Forwarding Efficiency",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "How often the canary server is adjusting video quality. This shows if the new version's bandwidth-management logic is active.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 0.01
              }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(osfu:budget_solver_outcomes_rate_5m)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Budget Decisions/s",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The rate at which the canary server is pausing video streams due to poor network. If this is much higher than the stable version, the new code may be too aggressive.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "osfu:budget_solver_paused_rate_5m",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Budget Pauses/s",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The rate at which the canary server is restoring paused streams. This proves that the 'auto-healing' logic in the new version is functional.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 0.01
              }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "id": 13,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "osfu:budget_solver_resumed_rate_5m",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Budget Resumes/s",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows when the canary server is prioritizing specific media (like active speakers) over bandwidth limits. Ensures the 'human priority' logic is working.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.02
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 5
      },
      "id": 14,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "osfu:budget_solver_protected_over_budget_rate_5m",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Protected Exceptions/s",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "A detailed timeline of users moving through the connection process on the canary server. Helps spot if users are getting 'stuck' at a specific stage.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (stage) (rate(osfu_ws_connections_total[5m]))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "title": "Join Stages",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Tracks rejections and startup errors on the canary server. Any sudden increase here means the new code is blocking users from joining.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(osfu_ws_startup_failures_total[5m]))",
          "legendFormat": "startup failures/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(osfu_ws_handshake_rejections_total[5m]))",
          "legendFormat": "handshake rejections/s",
          "refId": "B"
        }
      ],
      "title": "Admission Failures",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Measures how often users are losing their media connection on the canary. High churn means the new code might be less stable than the current version.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 7,
      "targets": [
        {
          "expr": "osfu:transport_disconnect_churn_per_user_5m",
          "legendFormat": "disconnects per active user",
          "refId": "A"
        },
        {
          "expr": "sum(osfu_transport_health_users{state=\"disconnected\"})",
          "legendFormat": "disconnected transports",
          "refId": "B"
        }
      ],
      "title": "Transport Churn",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Compares media coming into the canary versus media being processed. They should move in sync; if Ingress stays high while Forwarding drops, the canary is failing.",
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(osfu_rtp_packets_total{direction=\"ingress\"}[1m]))",
          "legendFormat": "ingress",
          "refId": "A"
        },
        {
          "expr": "sum(rate(osfu_rtp_forwarded_packets_total{destination=\"local_rtc\"}[1m]))",
          "legendFormat": "local_rtc",
          "refId": "B"
        }
      ],
      "title": "Ingress Versus Local Forwarding",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Measures the CPU load for media routing on the canary. If this is higher than the stable server for the same number of users, the new code is less efficient.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(osfu_rtc_datagram_fallback_scans_total[5m]))",
          "legendFormat": "fallback scans/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(osfu_rtc_datagram_scan_users_total[5m]))",
          "legendFormat": "scanned users/s",
          "refId": "B"
        }
      ],
      "title": "Routing Pressure",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "A combined view showing how the canary's automatic quality logic reacts to users' manual requests. This verifies the 'brain' of the new version.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 15,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "osfu:budget_solver_outcomes_rate_5m",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        },
        {
          "expr": "sum by (selector) (rate(osfu_source_selection_updates_total{selector=\"encoding\"}[5m]))",
          "legendFormat": "selector {{selector}}",
          "refId": "B"
        }
      ],
      "title": "Budget Adaptation During Canary",
      "type": "timeseries"
    },
