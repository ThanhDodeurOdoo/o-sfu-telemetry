{
  "annotations": {
    "list": []
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "The total number of users currently connected to the server. Use this to monitor the overall load and reach of the system.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(osfu_users_active)",
          "refId": "A"
        }
      ],
      "title": "Active Users",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The number of HTTP requests currently being processed by the server. High numbers might indicate the server is struggling to keep up with API requests.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(osfu_http_inflight_requests)",
          "refId": "A"
        }
      ],
      "title": "HTTP Inflight",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "A simple health check that verifies if the server's basic API is responsive. 1 means the server is responding, 0 means it is likely frozen or down.",
      "fieldConfig": {
        "defaults": {
          "unit": "bool"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "max(probe_success{job=\"o-sfu-noop\"})",
          "refId": "A"
        }
      ],
      "title": "Noop Probe",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "A more advanced health check that verifies if the internal diagnostic systems are functioning correctly. This ensures that the telemetry you see is accurate.",
      "fieldConfig": {
        "defaults": {
          "unit": "bool"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "osfu:diagnostics_probe_success",
          "refId": "A"
        }
      ],
      "title": "Diagnostics Probe",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows why WebSocket connections are being rejected (e.g., wrong credentials or server too busy). Each color represents a different rejection reason.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (close_code) (rate(osfu_ws_handshake_rejections_total[5m]))",
          "legendFormat": "{{close_code}}",
          "refId": "A"
        }
      ],
      "title": "Handshake Rejections by Close Code",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Tracks why active user sessions are ending. Common reasons include 'Normal Closure' or 'Network Timeout'. This helps identify stability issues.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (reason) (rate(osfu_ws_user_loop_exits_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "User Loop Exits by Reason",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Measures how long the server takes to respond to 95% of HTTP requests. Lower is better; sudden spikes indicate performance bottlenecks.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 7,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(osfu_http_request_duration_seconds_bucket[10m])))",
          "legendFormat": "{{route}} p95",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Duration p95",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows the time it takes for 95% of users to complete the initial connection handshake and authentication. High values lead to a 'slow' feel when joining.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(osfu_ws_handshake_duration_seconds_bucket[10m]))",
          "legendFormat": "handshake p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(osfu_ws_auth_duration_seconds_bucket[10m]))",
          "legendFormat": "auth p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, rate(osfu_ws_user_initialize_duration_seconds_bucket[10m]))",
          "legendFormat": "user init p95",
          "refId": "C"
        }
      ],
      "title": "Websocket Startup Duration p95",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "The number of users currently broadcasting their camera, microphone, or screen. This is the 'Input' side of the media flow.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 21
      },
      "id": 9,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(osfu_publications_active)",
          "refId": "A"
        }
      ],
      "title": "Active Publications",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The number of individual media streams being received by users. This is the 'Output' side and represents the actual bandwidth being consumed.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 21
      },
      "id": 10,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(osfu_subscriptions_active)",
          "refId": "A"
        }
      ],
      "title": "Active Subscriptions",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "A timeline view comparing how many people are broadcasting (publications) versus how many people are watching (subscriptions).",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "id": 11,
      "targets": [
        {
          "expr": "sum(osfu_publications_active)",
          "legendFormat": "publications",
          "refId": "A"
        },
        {
          "expr": "sum(osfu_subscriptions_active)",
          "legendFormat": "subscriptions",
          "refId": "B"
        }
      ],
      "title": "Live Media Totals",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "The number of messages waiting to be sent to users' browsers. If this grows, it means the server is sending data faster than the users' networks can receive it.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "id": 12,
      "targets": [
        {
          "expr": "osfu:ws_outbound_queue_depth",
          "legendFormat": "queued messages",
          "refId": "A"
        }
      ],
      "title": "Websocket Outbound Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "The rate at which the server is forced to disconnect 'slow' users because their message queue became too full. This protects the server's memory.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 29
      },
      "id": 13,
      "targets": [
        {
          "expr": "osfu:ws_outbound_queue_overflow_rate_5m",
          "legendFormat": "overflow rate",
          "refId": "A"
        }
      ],
      "title": "Websocket Outbound Queue Overflow Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
